{
  "permissions": {
    "allow": [
      "Bash(npm test:*)",
      "Bash(npm run coverage)",
      "Bash(npm run test:watch)",
      "Bash(npm start:*)",
      "Bash(node --check:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git fetch:*)",
      "Bash(git branch:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh repo view:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm test --silent 2>&1 | tail -8 || true"
          }
        ]
      }
    ]
  }
}
